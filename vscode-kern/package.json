{
  "name": "kern-lang",
  "displayName": "Kern Language",
  "description": "Syntax highlighting for Kern — the LLM-native language",
  "version": "0.1.0",
  "publisher": "cukas",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "kern",
        "aliases": ["Kern", "kern"],
        "extensions": [".kern", ".ir"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kern",
        "scopeName": "source.kern",
        "path": "./syntaxes/kern.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.typescript": "typescript"
        }
      }
    ]
  }
}
