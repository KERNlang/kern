{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kern",
  "scopeName": "source.kern",
  "patterns": [
    { "include": "#comment" },
    { "include": "#handler-block" },
    { "include": "#node-line" }
  ],
  "repository": {
    "comment": {
      "match": "//.*$",
      "name": "comment.line.double-slash.kern"
    },
    "handler-block": {
      "begin": "(<<<)\\s*$",
      "end": "^\\s*(>>>)",
      "beginCaptures": { "1": { "name": "punctuation.definition.block.begin.kern" } },
      "endCaptures": { "1": { "name": "punctuation.definition.block.end.kern" } },
      "contentName": "meta.embedded.block.typescript",
      "patterns": [{ "include": "source.ts" }]
    },
    "node-line": {
      "patterns": [
        { "include": "#theme-ref" },
        { "include": "#style-block" },
        { "include": "#pseudo-selector" },
        { "include": "#node-type-declaration" },
        { "include": "#node-type-state" },
        { "include": "#node-type-ui" },
        { "include": "#node-type-other" },
        { "include": "#prop-quoted-value" },
        { "include": "#prop-bare" },
        { "include": "#string" }
      ]
    },
    "node-type-ui": {
      "match": "(?<=^|\\s)(screen|page|row|col|card|grid|scroll|text|image|progress|divider|codeblock|section|form|button|input|textarea|slider|toggle|modal|list|item|tabs|tab|header|link|icon|svg|separator|table|thead|tbody|tr|th|td|scoreboard|metric|spinner|box|gradient|layout|loading|conditional|component|select|option|input-area|output-area|text-input|select-input|nav)\\b",
      "name": "keyword.control.kern"
    },
    "node-type-declaration": {
      "match": "(?<=^|\\s)(type|interface|field|fn|const|union|variant|service|method|singleton|constructor|module|export|import)\\b",
      "name": "keyword.declaration.kern"
    },
    "node-type-state": {
      "match": "(?<=^|\\s)(state|store|config|signal|machine|transition|model|column|relation|repository|dependency|inject|cache|entry|invalidate|event|prop|ref)\\b",
      "name": "storage.type.kern"
    },
    "node-type-other": {
      "match": "(?<=^|\\s)(server|route|middleware|handler|schema|stream|spawn|timer|on|env|websocket|params|auth|validate|respond|trigger|cli|command|arg|flag|repl|guard|parallel|dispatch|then|each|hook|provider|effect|logic|memo|callback|context|returns|render|derive|transform|action|assume|invariant|branch|path|resolve|candidate|discriminator|collect|pattern|apply|expect|recover|strategy|reason|evidence|needs|rule|message|template|slot|body|cleanup|error|test|describe|it|mcp|tool|resource|prompt|param|description|sampling|elicitation|metadata|generateMetadata|notFound|redirect|fetch)\\b",
      "name": "keyword.other.kern"
    },
    "style-block": {
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.definition.style.begin.kern" } },
      "endCaptures": { "0": { "name": "punctuation.definition.style.end.kern" } },
      "name": "meta.style-block.kern",
      "patterns": [
        { "include": "#pseudo-selector" },
        { "include": "#style-key-shorthand" },
        { "include": "#style-color" },
        { "include": "#style-number" },
        { "include": "#style-string" },
        {
          "match": ",",
          "name": "punctuation.separator.kern"
        },
        {
          "match": ":",
          "name": "punctuation.separator.key-value.kern"
        }
      ]
    },
    "pseudo-selector": {
      "match": ":(press|hover|active|focus)",
      "name": "entity.other.pseudo-selector.kern"
    },
    "style-key-shorthand": {
      "match": "\\b(p|pt|pb|pl|pr|m|mt|mb|ml|mr|bg|c|fs|fw|br|bw|bc|w|h|f|jc|ai|fd|ta|gap|shadow|border)\\b(?=:)",
      "name": "support.type.property-name.kern"
    },
    "style-color": {
      "match": "#[0-9A-Fa-f]{3,8}",
      "name": "constant.other.color.kern"
    },
    "style-number": {
      "match": "(?<=:)-?[0-9]+(\\.[0-9]+)?",
      "name": "constant.numeric.kern"
    },
    "style-string": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.kern"
    },
    "prop-quoted-value": {
      "match": "([a-zA-Z_][a-zA-Z0-9_-]*)=(\"[^\"]*\")",
      "captures": {
        "1": { "name": "entity.other.attribute-name.kern" },
        "2": { "name": "string.quoted.double.kern" }
      }
    },
    "prop-bare": {
      "match": "([a-zA-Z_][a-zA-Z0-9_-]*)=([^\\s{$\"]+)",
      "captures": {
        "1": { "name": "entity.other.attribute-name.kern" },
        "2": { "name": "variable.other.value.kern" }
      }
    },
    "theme-ref": {
      "match": "\\$([a-zA-Z_][a-zA-Z0-9_-]*)",
      "name": "variable.other.theme-ref.kern"
    },
    "string": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.kern"
    }
  }
}
