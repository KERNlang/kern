{
  "comments": { "lineComment": "//" },
  "brackets": [
    ["{", "}"],
    ["(", ")"],
    ["<<<", ">>>"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "<<<", "close": ">>>" }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "<<<", "close": ">>>" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(screen|page|layout|section|card|row|col|list|tabs|grid|conditional|button|scroll|modal|loading|error|fn|interface|service|machine|server|route|middleware|cli|command|mcp|tool|model|template)\\b",
    "decreaseIndentPattern": "^\\s*$"
  }
}
