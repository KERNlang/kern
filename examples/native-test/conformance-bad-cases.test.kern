test name="Bad KERN conformance" target="./conformance-bad-cases.kern" coverage=false
  it name="positive invariant assertions prove detector coverage"
    expect has=duplicateNames count=2 matches="User"
    expect has=deriveCycles count=1 matches="cycleA.*cycleB|cycleB.*cycleA"
    expect has=nonExhaustiveGuards count=1 matches="PaymentGuard"
    expect has=duplicateRoutes count=1 matches="POST /orders"
    expect has=emptyRoutes matches="GET /empty"
    expect has=unvalidatedRoutes matches="mutates without schema"
    expect has=unguardedEffects matches="database query"
    expect has=weakGuards count=1 matches="hasUser"
    expect has=rawHandlers matches="handler"
    expect has=duplicateParams count=1 matches="query"
    expect has=unguardedToolParams matches="url"
    expect has=missingPathGuards count=1 matches="filePath"
    expect has=ssrfRisks matches="fetchRemote|url"
    expect has=sensitiveEffectsRequireAuth matches="database query"
    expect has=routePathParams count=1 matches="id"
    expect has=effectWithoutCleanup count=1 matches="cleanup"
    expect has=unrecoveredAsync count=1 matches="recover"
