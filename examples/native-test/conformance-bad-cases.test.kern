test name="Bad KERN conformance" target="./conformance-bad-cases.kern"
  it name="positive invariant assertions prove detector coverage"
    expect has=duplicateNames matches="User"
    expect has=deriveCycles matches="cycleA.*cycleB|cycleB.*cycleA"
    expect has=nonExhaustiveGuards matches="PaymentGuard"
    expect has=duplicateRoutes matches="POST /orders"
    expect has=emptyRoutes matches="GET /empty"
    expect has=unvalidatedRoutes matches="mutates without schema"
    expect has=unguardedEffects matches="database query"
    expect has=weakGuards matches="hasUser"
    expect has=rawHandlers matches="handler"
    expect has=duplicateParams matches="query"
    expect has=unguardedToolParams matches="url"
    expect has=missingPathGuards matches="filePath"
    expect has=ssrfRisks matches="fetchRemote|url"
    expect has=sensitiveEffectsRequireAuth matches="database query"
    expect has=routePathParams matches="id"
    expect has=effectWithoutCleanup matches="cleanup"
    expect has=unrecoveredAsync matches="recover"
