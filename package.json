{
  "name": "kern-monorepo",
  "version": "3.1.9",
  "private": true,
  "type": "module",
  "description": "Kern — the LLM-native language. Monorepo for @kern/* packages.",
  "author": "cukas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KERNlang/kern.git"
  },
  "homepage": "https://github.com/KERNlang/kern#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "build": "tsc -b && pnpm --filter @kernlang/playground build",
    "test": "pnpm -r --filter '!@kernlang/review-python' test",
    "test:root": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.js",
    "fitness": "pnpm test",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "tree-sitter",
      "tree-sitter-python",
      "unrs-resolver"
    ],
    "overrides": {
      "dompurify@<3.3.2": ">=3.3.2",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "hono@<4.12.12": ">=4.12.12",
      "@hono/node-server@<1.19.13": ">=1.19.13"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  }
}
