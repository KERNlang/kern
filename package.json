{
  "name": "kern-monorepo",
  "version": "3.4.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "description": "Kern — the LLM-native language. Monorepo for @kern/* packages.",
  "author": "cukas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KERNlang/kern.git"
  },
  "homepage": "https://github.com/KERNlang/kern#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "build": "tsc -b && pnpm --filter @kernlang/playground build",
    "test": "pnpm -r --filter '!@kernlang/review-python' test",
    "test:kern": "pnpm --filter @kernlang/test build && node packages/test/dist/cli.js examples/native-test --coverage --min-coverage 100 && node packages/test/dist/cli.js packages/core/native-test --coverage --min-coverage 100",
    "test:root": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.js",
    "fitness": "pnpm test && pnpm test:kern",
    "check:repo": "node ./scripts/check-repo-consistency.mjs",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format --write",
    "prepare": "node ./scripts/install-git-hooks.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "tree-sitter",
      "tree-sitter-python",
      "unrs-resolver"
    ],
    "overrides": {
      "dompurify": ">=3.4.0",
      "brace-expansion": ">=5.0.5",
      "picomatch": ">=4.0.4",
      "hono": ">=4.12.14",
      "@hono/node-server": ">=1.19.13"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
