{
  "name": "@kernlang/terminal",
  "version": "3.4.2",
  "description": "Kern ANSI terminal rendering transpiler",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kern",
    "llm",
    "terminal",
    "ansi",
    "cli",
    "transpiler",
    "ai"
  ],
  "license": "AGPL-3.0",
  "scripts": {
    "build": "tsc -b",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.js"
  },
  "dependencies": {
    "@kernlang/core": "workspace:*"
  },
  "peerDependencies": {
    "@inkjs/ui": ">=2.0.0",
    "ink": ">=7.0.0",
    "react": ">=19.2.0"
  },
  "peerDependenciesMeta": {
    "@inkjs/ui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@inkjs/ui": "2.0.0",
    "ink": "7.0.1",
    "react": "19.2.5"
  }
}
