exports[`golden: machine full state machine 1`] = `
"export type OrderState = 'pending' | 'confirmed' | 'shipped' | 'delivered' | 'cancelled';

export class OrderStateError extends Error {
  constructor(
    public readonly expected: string | string[],
    public readonly actual: string,
  ) {
    const expectedStr = Array.isArray(expected) ? expected.join(' | ') : expected;
    super(\`Invalid order state: expected \${expectedStr}, got \${actual}\`);
    this.name = 'OrderStateError';
  }
}

/** pending → confirmed */
export function confirmOrder<T extends { state: OrderState }>(entity: T): T {
  if (entity.state !== 'pending') {
    throw new OrderStateError('pending', entity.state);
  }
  return { ...entity, state: 'confirmed' as OrderState };
}

/** confirmed → shipped */
export function shipOrder<T extends { state: OrderState }>(entity: T): T {
  if (entity.state !== 'confirmed') {
    throw new OrderStateError('confirmed', entity.state);
  }
  return { ...entity, state: 'shipped' as OrderState };
}

/** shipped → delivered */
export function deliverOrder<T extends { state: OrderState }>(entity: T): T {
  if (entity.state !== 'shipped') {
    throw new OrderStateError('shipped', entity.state);
  }
  return { ...entity, state: 'delivered' as OrderState };
}

/** pending|confirmed → cancelled */
export function cancelOrder<T extends { state: OrderState }>(entity: T): T {
  const validStates: OrderState[] = ['pending', 'confirmed'];
  if (!validStates.includes(entity.state)) {
    throw new OrderStateError(validStates, entity.state);
  }
  return { ...entity, state: 'cancelled' as OrderState };
}
"
`;

exports[`golden: machine transition with custom handler 1`] = `
"export type TaskState = 'open' | 'closed';

export class TaskStateError extends Error {
  constructor(
    public readonly expected: string | string[],
    public readonly actual: string,
  ) {
    const expectedStr = Array.isArray(expected) ? expected.join(' | ') : expected;
    super(\`Invalid task state: expected \${expectedStr}, got \${actual}\`);
    this.name = 'TaskStateError';
  }
}

/** open → closed */
export function closeTask<T extends { state: TaskState }>(entity: T): T {
  if (entity.state !== 'open') {
    throw new TaskStateError('open', entity.state);
  }
  return { ...entity, state: "closed", closedAt: Date.now() };
}
"
`;

