exports[`golden: store file-backed store 1`] = `
"import { readFileSync, writeFileSync, mkdirSync, readdirSync, unlinkSync } from 'node:fs';
import { join, resolve } from 'node:path';
import { homedir } from 'node:os';

const USER_DIR = join(homedir(), '.app/users');

function ensureUserDir(): void {
  mkdirSync(USER_DIR, { recursive: true });
}

function safeUserPath(id: string): string {
  const sanitized = id.replace(/[^a-zA-Z0-9_-]/g, '');
  if (!sanitized) throw new Error(\`Invalid ID: \${id}\`);
  const full = resolve(USER_DIR, \`\${sanitized}.json\`);
  if (!full.startsWith(resolve(USER_DIR))) throw new Error(\`Invalid ID: \${id}\`);
  return full;
}

export function saveUser(item: User): void {
  ensureUserDir();
  writeFileSync(safeUserPath((item as any).id), JSON.stringify(item, null, 2) + '\\n');
}

export function loadUser(id: string): User | null {
  try { return JSON.parse(readFileSync(safeUserPath(id), 'utf-8')) as User; }
  catch (e) { if ((e as NodeJS.ErrnoException).code === 'ENOENT') return null; throw e; }
}

export function listUsers(limit = 20): User[] {
  ensureUserDir();
  const files = readdirSync(USER_DIR).filter(f => f.endsWith('.json'));
  const items: User[] = [];
  for (const f of files) {
    try { items.push(JSON.parse(readFileSync(join(USER_DIR, f), 'utf-8')) as User); }
    catch { /* skip corrupt files */ }
  }
  return items.sort((a: any, b: any) => (b.updatedAt || '').localeCompare(a.updatedAt || '')).slice(0, limit);
}

export function deleteUser(id: string): boolean {
  try { unlinkSync(safeUserPath(id)); return true; }
  catch { return false; }
}"
`;

