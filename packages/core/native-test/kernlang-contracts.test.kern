test name="KERNlang native self contracts" target="./kernlang-contracts.kern"
  fixture name=adminUsers value={{[{ id: "u1", name: "Ada", role: "admin", active: true }]}}
  fixture name=memberUsers value={{[{ id: "u2", name: "Grace", role: "member", active: true }]}}
  fixture name=visibleUsers value={{[{ id: "u1", name: "Ada", role: "admin", active: true }, { id: "u2", name: "Grace", role: "member", active: true }]}}

  it name="core source stays valid before TypeScript codegen"
    expect no=schemaViolations
    expect no=semanticViolations
    expect node=interface name=User child=field count=4
    expect node=derive name=activeUsers

  it name="state and variant semantics stay native"
    expect machine=Order reaches=paid via=confirm,capture
    expect machine=Order transition=refund from=paid to=refunded
    expect guard=PaymentGuard exhaustive=true over=Payment
    expect preset=guard

  it name="runtime expressions prove typed data contracts"
    expect expr={{activeUsers.map((user) => user.id)}} equals={{["u1", "u2"]}}
    expect expr={{activeUsers.every((user) => user.active)}} equals=true

  it name="routes execute as source workflows"
    expect route="GET /users" with={{({ query: { role: "admin" } })}} returns={{adminUsers}}
    expect route="GET /users" returns={{visibleUsers}}
    expect route="GET /users/:id" with={{({ params: { id: "u1" } })}} returns={{({ id: "u1", name: "Ada", role: "admin", active: true })}}
    expect route="GET /users/:id" with={{({ params: { id: "bad" } })}} throws=ValidationError

  it name="tools and deterministic effects execute before backend codegen"
    expect tool=filterUsers with={{({ role: "member" })}} returns={{memberUsers}}
    expect tool=filterUsers with={{({ role: "<admin>" })}} returns={{adminUsers}}
    expect tool=readSafe with={{({ filePath: "/data/readme.md" })}} returns={{"/data/readme.md"}}
    expect tool=readSafe with={{({ filePath: "/etc/passwd" })}} throws=PathContainmentError
    expect effect=loadUsers returns={{visibleUsers}}

  it name="native coverage proves KERN source is first-class"
    expect preset=coverage
