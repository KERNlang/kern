{
  "name": "kern-lang",
  "version": "3.3.4",
  "description": "The language LLMs think in. Write one .kern file, ship 7 targets. 70% fewer tokens.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kern",
    "llm",
    "ir",
    "transpiler",
    "react",
    "nextjs",
    "react-native",
    "tailwind",
    "express"
  ],
  "author": "cukas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KERNlang/kern.git"
  },
  "homepage": "https://github.com/KERNlang/kern#readme",
  "license": "AGPL-3.0",
  "scripts": {
    "build": "tsc -b"
  },
  "dependencies": {
    "@kernlang/core": "workspace:*",
    "@kernlang/protocol": "workspace:*",
    "@kernlang/react": "workspace:*",
    "@kernlang/native": "workspace:*",
    "@kernlang/express": "workspace:*",
    "@kernlang/cli": "workspace:*",
    "@kernlang/terminal": "workspace:*",
    "@kernlang/vue": "workspace:*",
    "@kernlang/fastapi": "workspace:*",
    "@kernlang/metrics": "workspace:*"
  }
}
