{
  "name": "@kernlang/test",
  "version": "3.4.2",
  "description": "Native KERN structural test runner",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kern-test": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "kern",
    "test",
    "runner",
    "guards",
    "invariants"
  ],
  "license": "AGPL-3.0",
  "scripts": {
    "build": "tsc -b",
    "kern:compile": "pnpm --filter @kernlang/cli run build && node ../cli/dist/cli.js compile src/kern --outdir=src/generated",
    "kern:check": "pnpm run kern:compile && git diff --exit-code src/generated",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.js"
  },
  "dependencies": {
    "@kernlang/core": "workspace:*"
  },
  "devDependencies": {
    "@kernlang/cli": "workspace:*"
  }
}
