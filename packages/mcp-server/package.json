{
  "name": "@kernlang/mcp-server",
  "version": "3.4.0",
  "description": "KERN MCP server — compile, review, and analyze .kern files via MCP",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kern-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "kern",
    "mcp",
    "model-context-protocol",
    "ai",
    "llm",
    "dsl",
    "compiler",
    "transpiler",
    "code-generation",
    "review",
    "security",
    "claude",
    "cursor",
    "react",
    "nextjs",
    "express",
    "vue"
  ],
  "homepage": "https://kernlang.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/KERNlang/kern",
    "directory": "packages/mcp-server"
  },
  "author": "Nicolas Cukas",
  "license": "AGPL-3.0",
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --passWithNoTests --config jest.config.js"
  },
  "dependencies": {
    "@kernlang/core": "workspace:*",
    "@kernlang/express": "workspace:*",
    "@kernlang/fastapi": "workspace:*",
    "@kernlang/mcp": "workspace:*",
    "@kernlang/react": "workspace:*",
    "@kernlang/review": "workspace:*",
    "@kernlang/review-mcp": "workspace:*",
    "@kernlang/terminal": "workspace:*",
    "@kernlang/vue": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "express": "^5.2.1"
  }
}
