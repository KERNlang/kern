  }
  for (const key of requiredKeys) {
    if (!(key in value)) {
      throw new Error(\`Invalid \${label}: missing \${key}\`);
    }
  }
}

export function registerPostApiTracksAnalyzeRoute(app: Express): void {
  app.post('/api/tracks/analyze', async (req: Request<RouteParams, ResponseBody, RequestBody, RequestQuery>, res: Response, next: NextFunction) => {
    try {
      assertRequiredFields('body', req.body, ['trackId']);
    } catch (err) {
      return res.status(400).json({ error: err instanceof Error ? err.message : String(err) } as any);
    }

    try {
            const { trackId, options } = req.body;
            const result = await analyzeTrack(trackId, options);
            res.json(result);
    } catch (error) {
