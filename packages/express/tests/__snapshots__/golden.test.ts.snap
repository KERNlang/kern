exports[`Golden Snapshot Tests Express output for api-routes.kern: artifact: routes/delete-api-tracks-id.ts 1`] = `
"import { type Express, type NextFunction, type Request, type Response } from 'express';
import { requireowner } from '../middleware/requireowner.js';

type RouteParams = { id: string };
type RequestQuery = Record<string, never>;
type RequestBody = Record<string, never>;
type ResponseBody = unknown;

function assertRequiredFields(label: string, value: unknown, requiredKeys: string[]): void {
  if (typeof value !== 'object' || value === null) {
    throw new Error(\`Invalid \${label}: expected object payload\`);
  }
  for (const key of requiredKeys) {
    if (!(key in value)) {
      throw new Error(\`Invalid \${label}: missing \${key}\`);
    }
  }
}

export function registerDeleteApiTracksIdRoute(app: Express): void {
  app.delete('/api/tracks/:id', requireowner, async (req: Request<RouteParams, ResponseBody, RequestBody, RequestQuery>, res: Response, next: NextFunction) => {
    try {
      assertRequiredFields('params', req.params, ['id']);
    } catch (err) {
      return res.status(400).json({ error: err instanceof Error ? err.message : String(err) } as any);
    }

    try {
            await db.tracks.delete(req.params.id);
            res.status(204).send();
    } catch (error) {
      next(error);
    }
  });
}"
`;

exports[`Golden Snapshot Tests Express output for api-routes.kern: artifact: routes/get-api-tracks.ts 1`] = `
"import { type Express, type NextFunction, type Request, type Response } from 'express';

type RouteParams = Record<string, never>;
type RequestQuery = Record<string, never>;
type RequestBody = Record<string, never>;
type ResponseBody = unknown;

export function registerGetApiTracksRoute(app: Express): void {
  app.get('/api/tracks', async (req: Request<RouteParams, ResponseBody, RequestBody, RequestQuery>, res: Response, next: NextFunction) => {
    try {
            const tracks = await db.tracks.findAll({ userId: req.user.id });
            res.json(tracks);
    } catch (error) {
      next(error);
    }
  });
}"
`;

exports[`Golden Snapshot Tests Express output for api-routes.kern: artifact: routes/get-api-tracks-id.ts 1`] = `
"import { type Express, type NextFunction, type Request, type Response } from 'express';

type RouteParams = { id: string };
type RequestQuery = Record<string, never>;
type RequestBody = Record<string, never>;
type ResponseBody = unknown;

function assertRequiredFields(label: string, value: unknown, requiredKeys: string[]): void {
  if (typeof value !== 'object' || value === null) {
    throw new Error(\`Invalid \${label}: expected object payload\`);
  }
  for (const key of requiredKeys) {
    if (!(key in value)) {
      throw new Error(\`Invalid \${label}: missing \${key}\`);
    }
  }
}

export function registerGetApiTracksIdRoute(app: Express): void {
  app.get('/api/tracks/:id', async (req: Request<RouteParams, ResponseBody, RequestBody, RequestQuery>, res: Response, next: NextFunction) => {
    try {
      assertRequiredFields('params', req.params, ['id']);
    } catch (err) {
      return res.status(400).json({ error: err instanceof Error ? err.message : String(err) } as any);
    }

    try {
            const track = await db.tracks.findById(req.params.id);
            if (!track) return res.status(404).json({ error: 'Not found' });
            res.json(track);
    } catch (error) {
      next(error);
    }
  });
}"
`;

