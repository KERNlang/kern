        <Text style={styles.text_2} key="settings.exportDefaultsDescription" tag="p">
          {"Set your preferred export format."}
        </Text>
        <View ref="ExportDefaultsSection" props="isPro,exportFormat,mp3Bitrate" />
      </View>
      <View style={styles.divider_3} />
      <View key="settings.audioTab.defaultSensitivity" title="Default Analysis Sensitivity">
        <View style={styles.card_4}>
          <View ref="PresetSelector" bind="presetId" onChange="selectPreset" props="isPro" />
          <Text style={styles.text_5}>
            {"This preset will be used as the starting point when analyzing new tracks."}
          </Text>
        </View>
      </View>
      <View key="settings.audioTab.fixStrength" title="Fix Strength" icon="infoCircle" tooltip="fixStrengthNote">
        <View style={styles.card_6}>
          <View style={styles.row_7}>
            <Text style={styles.text_8}>
              {"Controls how aggressive auto-fix EQ cuts are applied."}
            </Text>
            <Text style={styles.text_9} bind="fixStrengthDb" format="{v} dB ({presetLabel})" />
          </View>
          <View min="2" max="6" step="0.1" bind="fixStrengthDb" onDoubleClick="4.0" accent="#f97316" />
          <View style={styles.row_10}>
            <Text style={styles.text_11}>
              {"Conservative (2dB)"}
            </Text>
            <Text style={styles.text_12}>
              {"Industry Standard (4dB)"}
            </Text>
            <Text style={styles.text_13}>
              {"Aggressive (6dB)"}
            </Text>
          </View>
          <Text style={styles.text_14} bind="strengthDescription" />
        </View>
      </View>
      <View key="settings.audioTab.stemPresence" title="Stem Presence Threshold" icon="infoCircle" tooltip="stemPresenceTooltip">
        <View style={styles.card_15}>
          <Text style={styles.text_16}>
            {"Stems quieter than this threshold are considered not present and skipped."}
          </Text>
          <View style={styles.row_17}>
            <Text style={styles.text_18}>
              {"Threshold"}
            </Text>
            <Text style={styles.text_19} bind="presenceThreshold" format="{v} LUFS" />
          </View>
          <View min="-80" max="-30" step="5" bind="presenceThreshold" accent="#f97316" />
          <View style={styles.row_20}>
            <Text style={styles.text_21}>
              {"-80 (Sensitive)"}
            </Text>
            <Text style={styles.text_22}>
              {"-40 (Standard)"}
            </Text>
            <Text style={styles.text_23}>
              {"-30 (Strict)"}
            </Text>
          </View>
          <View style={styles.card_24}>
            <Text style={styles.text_25}>
              {"Current setting:"}
            </Text>
            <Text style={styles.text_26} bind="presenceDescription" />
          </View>
        </View>
      </View>
      <View key="settings.audioTab.perStem" title="Per-Stem Detection Thresholds" icon="infoCircle" tooltip="perStemTooltip">
        <View style={styles.card_27}>
          <Text style={styles.text_28}>
            {"Industry-informed thresholds for each stem type."}
          </Text>
          <View cols="2" gap="24">
            <View ref="StemThresholdSlider" stem="drums" bind="perStemThresholds.drums" default="-30" disabled="!isPro" />
            <View ref="StemThresholdSlider" stem="bass" bind="perStemThresholds.bass" default="-35" disabled="!isPro" />
            <View ref="StemThresholdSlider" stem="vocals" bind="perStemThresholds.vocals" default="-30" disabled="!isPro" />
            <View ref="StemThresholdSlider" stem="guitar" bind="perStemThresholds.guitar" default="-45" disabled="!isPro" />
            <View ref="StemThresholdSlider" stem="piano" bind="perStemThresholds.piano" default="-45" disabled="!isPro" />
            <View ref="StemThresholdSlider" stem="other" bind="perStemThresholds.other" default="-50" disabled="!isPro" />
          </View>
          <View if="isPro&perStemMode=manual">
            <View style={styles.divider_29} />
            <TouchableOpacity style={styles.button_30} icon="rotate" variant="secondary" size="sm" onClick="resetPerStemThresholds">
              <Text style={styles.buttonText}>Reset to Industry Defaults</Text>
            </TouchableOpacity>
          </View>
          <View if="!isPro">
            <View style={styles.divider_31} />
            <View style={styles.card_32}>
              <View style={styles.row_33}>
                <View style={styles.icon_34} name="lock" />
