                  </Text>
                </View>
              </View>
            </View>
          </View>
        </View>
      </View>
      <View if="isPro">
        <View key="settings.audioTab.customThresholds" title="Custom Thresholds Configuration">
          <View style={styles.card_37}>
            <Text style={styles.text_38}>
              {"Fine-tune the tolerance levels for the Custom preset."}
            </Text>
            <View ref="ToleranceSliders" bind="customThresholds" onChange="setThreshold" disabled="!isPro" />
          </View>
        </View>
      </View>
      <View style={styles.divider_39} />
      <View key="settings.audioTab.signalProcessing" title="Signal Processing">
        <View style={styles.card_40}>
          <View style={styles.row_41}>
            <View>
              <Text style={styles.text_42}>
                {"Normalize Reference Loudness"}
              </Text>
              <Text style={styles.text_43}>
                {"Automatically adjust reference track gain to match your mix (LUFS matching)."}
              </Text>
            </View>
            <View bind="normalizeReference" accent="#ea580c" />
          </View>
        </View>
      </View>
    </View>
