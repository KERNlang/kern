action name=mcp-tool-poisoning
  reason value="CWE-1427, OWASP MCP02"
  config severity=error confidence=0.85 category=bug

  effect name=prompt-injection kind=injection
    pattern lang=ts flags=i match="ignore\s+(previous|above|all)\s+(instructions?|prompts?|context)"
    pattern lang=ts flags=i match="disregard\s+(previous|above|all)"
    pattern lang=ts flags=i match="you\s+are\s+now\b"
    pattern lang=ts flags=i match="new\s+instructions?:"
    pattern lang=ts flags=im match="^\s*system\s*:"
    pattern lang=ts match="<\|system\|>"
    pattern lang=ts match="<\|end\|>"
    pattern lang=ts match="\[INST\]"
    pattern lang=ts match="</?s>"
    pattern lang=ts match="<<SYS>>"
    pattern lang=py flags=i match="ignore\s+(previous|above|all)\s+(instructions?|prompts?|context)"
    pattern lang=py flags=i match="disregard\s+(previous|above|all)"
    pattern lang=py flags=i match="you\s+are\s+now\b"
    pattern lang=py flags=i match="new\s+instructions?:"
    pattern lang=py flags=im match="^\s*system\s*:"
    pattern lang=py match="<\|system\|>"
    pattern lang=py match="<\|end\|>"
    pattern lang=py match="\[INST\]"
    pattern lang=py match="</?s>"
    pattern lang=py match="<<SYS>>"

  effect name=invisible-chars kind=injection
    pattern lang=ts match="[\u200B\u200C\u200D\u200E\u200F\u202A-\u202E\u2060\u2061\u2062\u2063\u2064\uFEFF\u00AD]"
    pattern lang=py match="[\u200B\u200C\u200D\u200E\u200F\u202A-\u202E\u2060\u2061\u2062\u2063\u2064\uFEFF\u00AD]"

  effect name=direction-override kind=injection
    pattern lang=ts match="[\u202A\u202B\u202C\u202D\u202E\u2066\u2067\u2068\u2069]"
    pattern lang=py match="[\u202A\u202B\u202C\u202D\u202E\u2066\u2067\u2068\u2069]"

  effect name=role-boundary-escape kind=injection
    pattern lang=ts flags=im match="^(Human|User|Assistant|System|Developer|Bot)\s*:"
    pattern lang=ts match="</(tool|function|result|system|instruction)>"
    pattern lang=py flags=im match="^(Human|User|Assistant|System|Developer|Bot)\s*:"
    pattern lang=py match="</(tool|function|result|system|instruction)>"

  effect name=encoded-description kind=injection
    pattern lang=ts match="Buffer\.from\s*\(.*base64"
    pattern lang=ts match="\batob\s*\("
    pattern lang=py match="base64\.b64decode\s*\("
    pattern lang=py match="codecs\.decode\s*\("

  effect name=html-markdown-injection kind=injection
    pattern lang=ts match="<!--.*-->"
    pattern lang=ts flags=i match="\]\(\s*javascript:"
    pattern lang=ts flags=i match="!\[.*\]\(data:"
    pattern lang=py match="<!--.*-->"
    pattern lang=py flags=i match="\]\(\s*javascript:"
    pattern lang=py flags=i match="!\[.*\]\(data:"

  guard name=none kind=validation
    pattern lang=ts match="THIS_GUARD_NEVER_MATCHES_SENTINEL_DO_NOT_REMOVE"
    pattern lang=py match="THIS_GUARD_NEVER_MATCHES_SENTINEL_DO_NOT_REMOVE"

  invariant name=poisoned-description
    expect from=tool-description to=prompt-injection guarded-by="none"
    evidence value="Tool description contains prompt injection pattern — tool poisoning risk"
    suggestion value="Tool descriptions should only describe the tool's functionality. Remove any instruction-like content."

  invariant name=invisible-description
    expect from=tool-description to=invisible-chars guarded-by="none"
    evidence value="Tool description contains invisible Unicode characters — possible hidden instruction attack"
    suggestion value="Remove zero-width spaces, direction overrides, and other invisible characters from tool descriptions."

  invariant name=direction-override-description
    expect from=tool-description to=direction-override guarded-by="none"
    evidence value="Tool description contains Unicode direction override characters — text may appear differently to humans vs LLMs"
    suggestion value="Remove Unicode bidirectional override characters from tool descriptions."

  invariant name=boundary-escape
    expect from=tool-description to=role-boundary-escape guarded-by="none"
    evidence value="Tool description contains conversation turn delimiter or XML boundary escape — context manipulation risk"
    suggestion value="Remove turn delimiters (Human:/Assistant:) and XML closing tags from tool descriptions."

  invariant name=encoded-description
    expect from=source-code to=encoded-description guarded-by="none"
    evidence value="Tool description uses runtime decoding (base64/atob) — possible obfuscated prompt injection"
    suggestion value="Use plain string literals for tool descriptions. Encoded descriptions hide content from review."

  invariant name=hidden-markup
    expect from=tool-description to=html-markdown-injection guarded-by="none"
    evidence value="Tool description contains hidden HTML/markdown — content invisible to humans but parsed by LLMs"
    suggestion value="Remove HTML comments, javascript: links, and data: image URIs from tool descriptions."
