  },
  "dependencies": {
    "@kern/core": "workspace:*",
    "@kern/express": "workspace:*",
    "@kern/metrics": "workspace:*",
    "@kern/native": "workspace:*",
    "@kern/react": "workspace:*",
    "@kern/review": "workspace:*",
    "@kern/terminal": "workspace:*",
    "@kern/vue": "workspace:*",
    "chokidar": "^5.0.0",
    "jiti": "^2.6.1"
  }
