{
  "name": "@kern/cli",
  "version": "2.0.0",
  "description": "KERN CLI — transpile, compile, minify, and analyze .kern files",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kern": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./transpiler-cli": "./dist/transpiler-cli.js"
  },
  "files": [
    "dist"
  ],
  "license": "AGPL-3.0",
