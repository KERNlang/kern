{
  "name": "@kernlang/cli",
  "version": "3.3.8",
  "description": "KERN CLI — transpile, compile, minify, and analyze .kern files",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kern": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./transpiler-cli": "./dist/transpiler-cli.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kern",
    "llm",
    "cli",
    "transpiler",
    "compiler",
    "review",
    "ai"
  ],
  "license": "AGPL-3.0",
  "scripts": {
    "build": "tsc -b",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.js"
  },
  "dependencies": {
    "@kernlang/codemod": "workspace:*",
    "@kernlang/core": "workspace:*",
    "@kernlang/evolve": "workspace:*",
    "@kernlang/express": "workspace:*",
    "@kernlang/fastapi": "workspace:*",
    "@kernlang/mcp": "workspace:*",
    "@kernlang/metrics": "workspace:*",
    "@kernlang/native": "workspace:*",
    "@kernlang/react": "workspace:*",
    "@kernlang/review": "workspace:*",
    "@kernlang/review-mcp": "workspace:*",
    "@kernlang/terminal": "workspace:*",
    "@kernlang/vue": "workspace:*",
    "chokidar": "^5.0.0",
    "jiti": "^2.6.1",
    "typescript": "^6.0.3"
  }
}
